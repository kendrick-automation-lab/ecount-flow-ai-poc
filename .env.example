ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── 실계정 연동 (선택) — 이카운트 ──
# 무료 데모체험 가입 → 테스트 회사 생성 → Self-Customizing→정보관리→API인증키발급(Test Key)
# ECOUNT_COM_CODE=회사코드
# ECOUNT_USER_ID=사용자ID
# ECOUNT_API_KEY=발급받은_Test_Key
# ECOUNT_TEST=true          # true=테스트존(sboapi) / false=실서버(oapi)
# 확인:  python scripts/ecount_connect_test.py
#
# ── Flow OpenAPI = 유료 '비즈니스 프로' 플랜 전용 (무료 불가, 확인됨) ──
# FLOW_API_KEY=... / FLOW_BOT_ID=... / FLOW_BOT_PROPERTY=... / FLOW_BOT_PASSWORD=...
#
# ── Airtable (데이터 실연동 — 게이트 없음) ──
# AIRTABLE_TOKEN=pat...
# AIRTABLE_BASE_ID=app...
# 확인: python scripts/airtable_connect_test.py  →  python scripts/airtable_seed.py
#
# ── Slack (협업툴 실연동 — Tier 3 대화형 Jarvis) ──
# SLACK_BOT_TOKEN=xoxb-...     # OAuth & Permissions (chat:write, app_mentions:read)
# SLACK_APP_TOKEN=xapp-...     # Socket Mode
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # (단순 1채널 발송용, 선택)
# 실행: python scripts/slack_jarvis_listen.py   →  #jarvis 에서 @봇 멘션
